<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cmail Dashboard</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <!-- 🔗 Connects your standalone mail.css sheet! -->
    <link rel="stylesheet" href="mail.css">
</head>
<body>

    <header class="gmail-header">
        <div class="header-left">
            <a href="dashboard.html" class="menu-icon" title="Return to Dashboard">◀</a>
            <div class="brand-node">
                <div class="brand-logo-badge">CM</div>
                <span class="brand-text-label">Cmail</span>
            </div>
        </div>
        <div class="search-container">
            <span class="search-icon-placeholder">🔍</span>
            <input type="text" class="search-bar" placeholder="Search mail">
        </div>
        <div class="header-right">
            <div id="userBadgeIcon" class="user-avatar-chip">J</div>
        </div>
    </header>

    <div class="app-body">
        <nav class="navigation-sidebar">
            <button class="compose-action-pill" onclick="openComposeFormView()">✏️ Compose</button>
            <div id="f-inbox" class="folder-item-row active" onclick="switchActiveFolder('inbox')">
                <span>Inbox</span> <span id="inboxBadge" class="folder-badge-count">2</span>
            </div>
            <div id="f-sent" class="folder-item-row" onclick="switchActiveFolder('sent')"><span>Sent</span></div>
            <div id="f-spam" class="folder-item-row" onclick="switchActiveFolder('spam')">
                <span>Spam</span> <span id="spamBadge" class="folder-badge-count">1</span>
            </div>
        </nav>

        <main class="content-workspace">
            <div id="emailListContainer" class="email-stream-list"></div>
            <div id="readingWorkspacePane" class="message-reading-pane" style="display: flex;">
                <div class="pane-header-subject">
                    <h2 id="txtSubject">Select a message parameters thread</h2>
                    <button onclick="deleteCurrentEmail()" style="background:none; border:none; cursor:pointer; font-size:16px;">🗑️</button>
                </div>
                <div id="txtSender" class="pane-meta-sender">From: system</div>
                <div id="txtBody" class="pane-body-context">Click an email inside the side row stream list to review contents logs variables.</div>
            </div>

            <div id="composeWorkspacePane" class="compose-window-modal">
                <div class="compose-header-label">New Message</div>
                <input type="text" id="formTo" class="compose-input-field" placeholder="Recipients">
                <input type="text" id="formSubject" class="compose-input-field" placeholder="Subject">
                <textarea id="formBody" class="compose-input-field" placeholder="Type email message body properties here..." style="flex:1; resize:none; padding:15px;"></textarea>
                <div style="display: flex; gap: 8px; margin-top: 10px;">
                    <button class="pill-submit-btn" onclick="emitCompiledMail()">Send</button>
                    <button class="flat-cancel-btn" onclick="closeComposeFormView()">Cancel</button>
                </div>
            </div>
        </main>
    </div>

    <!-- 🔗 Connects your standalone mail.js script! -->
    <script src="mail.js"></script>
</body>
</html>
